# Spanner Omni (local). Override only if you change docker-compose ports / IDs.
SPANNER_EMULATOR_HOST=localhost:15000
SPANNER_PROJECT_ID=default
SPANNER_INSTANCE_ID=default
SPANNER_DATABASE_ID=history-db

# PostgreSQL (local docker-compose).
PG_HOST=localhost
PG_PORT=5432
PG_USER=admin
PG_PASSWORD=password
PG_DATABASE=postgres

# CLI ETL: path to the Chrome History SQLite file.
# Also overridable via `npm run etl:sqlite-to-pg -- /path/to/History`.
# HISTORY_PATH=/absolute/path/to/Chrome/Default/History
